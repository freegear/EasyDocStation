{
  "name": "easydocstation",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "ollama:serve": "node scripts/ollama-serve-safe.mjs",
    "dev:frontend": "vite",
    "dev:backend": "PYTHON_BIN=${PYTHON_BIN:-python3} npm run dev --prefix server",
    "dev": "concurrently -p \"[{name}]\" -n \"Ollama,FE,BE\" -c \"cyan,magenta,green\" \"npm run ollama:serve\" \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:ubuntu": "bash scripts/dev-ubuntu.sh",
    "restart:ubuntu": "bash scripts/restart-ubuntu.sh",
    "restart:dgx-spark": "bash scripts/restart-dgx-spark.sh",
    "setup:ubuntu": "bash scripts/setup-ubuntu.sh",
    "version:bump": "node scripts/bump-app-version.mjs",
    "build": "vite build",
    "lint": "eslint .",
    "test:e2e": "playwright test",
    "preview": "vite preview",
    "setup:dgx-spark": "bash scripts/setup-dgx-spark.sh",
    "dev:dgx-spark": "bash scripts/dev-dgx-spark.sh"
  },
  "dependencies": {
    "@tiptap/extension-dropcursor": "^3.22.4",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/extension-table-of-contents": "^3.22.4",
    "@tiptap/extension-table": "^3.22.4",
    "@tiptap/extension-table-cell": "^3.22.4",
    "@tiptap/extension-table-header": "^3.22.4",
    "@tiptap/extension-table-row": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-to-print": "^3.3.0",
    "remark-gfm": "^4.0.1",
    "tiptap-extension-resize-image": "^1.3.3",
    "tiptap-markdown": "^0.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.55.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.19"
  }
}
