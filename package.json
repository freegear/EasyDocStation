{
  "name": "easydocstation",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "ollama:serve": "node scripts/ollama-serve-safe.mjs",
    "dev:frontend": "vite",
    "dev:backend": "npm run dev --prefix server",
    "dev": "concurrently -p \"[{name}]\" -n \"Ollama,FE,BE\" -c \"cyan,magenta,green\" \"npm run ollama:serve\" \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.4"
  }
}
